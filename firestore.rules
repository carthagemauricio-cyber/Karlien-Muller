rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /appointments/{appId} {
      allow read, write: if true;
    }

    match /public_slots/{slotId} {
      allow read, write: if true;
    }

    match /services/{serviceId} {
      allow read, write: if true;
    }

    match /professionals/{profId} {
      allow read, write: if true;
    }
  }
}
